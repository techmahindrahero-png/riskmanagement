# Database
DATABASE_URL=postgresql://grc_user:grc_password@localhost:5432/grc_db

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=grc-realm
KEYCLOAK_CLIENT_ID=grc-client
KEYCLOAK_CLIENT_SECRET=grc-secret

# Ollama/AI
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# App
DEBUG=True
