# Database Configuration
DATABASE_URL=postgresql://grc_user:grc_password@localhost:5432/grcdb
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=grcdb
DATABASE_USER=grc_user
DATABASE_PASSWORD=grc_password

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Keycloak Configuration
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=grc
KEYCLOAK_CLIENT_ID=grc-app
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Ollama Configuration
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama2
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=1000

# FastAPI Configuration
APP_TITLE=GRC Platform API
APP_VERSION=1.0.0
APP_DESCRIPTION=Integrated Governance, Risk & Compliance Platform
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000
REACT_APP_API_TIMEOUT=30000
REACT_APP_KEYCLOAK_URL=http://localhost:8080
REACT_APP_KEYCLOAK_REALM=grc
REACT_APP_KEYCLOAK_CLIENT=grc-app

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Email Configuration (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@grcplatform.com

# Environment
ENVIRONMENT=development
TIMEZONE=UTC
